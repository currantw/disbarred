{
  "manifest_version": 3,
  "name": "Disbarred",
  "version": "1.0.0",
  "description": "Hide/unhide elements on websites with custom keyboard shortcuts",
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*", "https://github.com/*/*/issues/*"],
      "js": ["content.js"]
    }
  ]
}
