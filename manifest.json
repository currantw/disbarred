{
  "manifest_version": 3,
  "name": "Disbarred",
  "version": "1.0.0",
  "description": "Hide/unhide elements on websites with custom keyboard shortcuts",
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["content.js"]
    }
  ]
}
